# Postgres checkpointer (matches docker-compose.yml). If unset, the agent falls
# back to an in-memory checkpointer (durable resume across processes won't work).
DATABASE_URL=postgresql://pruser:prpass@localhost:5432/prreview

# The single LLM call site (review node). Leave USE_LLM=false to run the graph
# fully offline with a deterministic stub reviewer (no key needed).
USE_LLM=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# GitHub PAT (fine-grained, pull requests: write). When set, ingest fetches the
# real PR/diff and post writes a real comment. Unset -> offline mocks.
# Set USE_GITHUB=false to force mocks even when a token is present.
GITHUB_TOKEN=
USE_GITHUB=
