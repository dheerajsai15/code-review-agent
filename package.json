{
  "name": "pr-review-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous GitHub PR review agent (LangGraph.js MVP)",
  "scripts": {
    "review": "tsx src/cli.ts review",
    "resume": "tsx src/cli.ts resume",
